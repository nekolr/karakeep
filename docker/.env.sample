# See https://docs.karakeep.app/configuration for more information
DATA_DIR=/data
MEILI_ADDR=http://127.0.0.1:7700
MEILI_MASTER_KEY=[generate with <openssl rand -base64 36 | tr -dc 'A-Za-z0-9'>]
NEXTAUTH_URL=http://localhost:3000
NEXTAUTH_SECRET=[generate with <openssl rand -base64 36>]
# Optional: tag used for the local Ubuntu desktop Chrome image build
KARAKEEP_CHROME_TAG=local
# Optional: Ubuntu apt mirror used while building the desktop Chrome image
UBUNTU_APT_MIRROR=http://mirrors.aliyun.com/ubuntu/
# Optional: publish the desktop browser locally
KARAKEEP_CHROME_DESKTOP_PORT=127.0.0.1:6080:6080
KARAKEEP_CHROME_DEBUG_PORT=127.0.0.1:9222:9222


# Optional: proxy settings for the desktop Chrome container
# CHROME_PROXY_SERVER=http://proxy.example.com:7890
# CHROME_PROXY_BYPASS_LIST=localhost;127.0.0.1;chrome;meilisearch
# CHROME_PROXY_PAC_URL=http://proxy.example.com/proxy.pac

# Optional: fallback for environments where Chrome sandboxing fails
# CHROME_DISABLE_SANDBOX=true


# Optional: wait extra time after navigation before capturing a page
# CRAWLER_POST_NAVIGATION_WAIT_MS=15000
